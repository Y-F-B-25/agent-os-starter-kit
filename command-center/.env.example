# Command Center configuration. Copy to .env and edit.
# Nothing here is secret. These are paths and ports for YOUR machine.

# Root of your agent workspace (required).
AGOS_PROJECT_ROOT=/path/to/your/workspace

# Vault layout. Defaults derive from AGOS_PROJECT_ROOT/vault if unset.
# AGOS_VAULT_ROOT=/path/to/your/workspace/vault
# AGOS_SESSIONS_DIR=/path/to/your/workspace/vault/Sessions
# AGOS_INBOX_ROOT=/path/to/your/workspace/vault/VaultBus/Commands/inbox
# AGOS_BRAIN_INDEX=/path/to/your/workspace/vault/INDEX.md

# Where your Claude Code session JSONLs live.
# AGOS_JSONL_DIR=/Users/you/.claude/projects

# Daemon HTTP port.
AGOS_CC_PORT=8787

# Label shown when the human (not an agent) posts from the UI.
AGOS_OWNER_LABEL=owner

# Optional: local runtime state dir (defaults to daemon/state).
# AGOS_STATE_DIR=/path/to/your/workspace/command-center/daemon/state

# Optional: daemon log dir.
# AGOS_LOG_DIR=/path/to/your/workspace/logs/cc-daemon

# Frontend: override the daemon URL at build time if not on the default.
# VITE_DAEMON_HTTP=http://127.0.0.1:8787
# VITE_DAEMON_WS=ws://127.0.0.1:8787/api/stream
